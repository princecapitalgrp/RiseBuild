platform :ios, '13.4'

prepare_react_native_project!

target 'risebysolis' do
  config = use_native_modules!

  # Flags to enable extra React Native features
  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true
  )

  # Explicitly merge the single post_install configuration block
     post_install do |installer|
    react_native_post_install(installer) if respond_to?(:react_native_post_install)
    __apply_Xcode_12_and_greater_settings(installer) if respond_to?(:__apply_Xcode_12_and_greater_settings)

    # BRUTE FORCE COMPILER ATTRIBUTE PATENTS
    installer.pods_project.targets.each do |target|
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          # Force C++17 language rules to remove consteval validation
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          
          # Append the global preprocessor bypass flag directly to the target compiler execution array
          config.build_settings['OTHER_CFLAGS'] = '$(inherited) -DFMT_USE_CONSTEVAL=0 -DFMT_CONSTEVAL='
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -DFMT_USE_CONSTEVAL=0 -DFMT_CONSTEVAL='
        end
      end
    end
  end


    # 2. HARD CODE PATCH: Turn off consteval inside the fmt source files entirely
    fmt_base_header = File.join(installer.sandbox.root.to_s, 'fmt', 'include', 'fmt', 'base.h')
    if File.exist?(fmt_base_header)
      contents = File.read(fmt_base_header)
      unless contents.include?('// Xcode Workaround')
        patched = contents.gsub(
          /^(#elif defined\(__cpp_consteval\)\n#  define FMT_USE_CONSTEVAL) 1/,
          "// Xcode Workaround: disable consteval\n\\1 0"
        )
        if patched != contents
          File.chmod(0644, fmt_base_header)
          File.write(fmt_base_header, patched)
          puts "⚡ Successfully patched fmt library header to bypass Xcode consteval checks!"
        end
      end
    end
  end

