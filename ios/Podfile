# FORCE ACCURATE WORKING DIRECTORY ASSIGNMENT
project_root = '/Volumes/Macintosh_HD/Users/user950783/RiseBuild'

require File.expand_path('node_modules/react-native/scripts/react_native_pods', project_root)
require File.expand_path('node_modules/@react-native-community/cli-platform-ios/native_modules', project_root)

platform :ios, '13.4'

prepare_react_native_project!

workspace 'risebysolis.xcworkspace'

target 'risebysolis' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true
  )

  use_expo_modules!

  post_install do |installer|
    react_native_post_install(installer) if respond_to?(:react_native_post_install)
    __apply_Xcode_12_and_greater_settings(installer) if respond_to?(:__apply_Xcode_12_and_greater_settings)

    installer.pods_project.targets.each do |target|
      # 1. FORCE SWIFT 5 TARGET COMPILATION (Fixes Sendable errors)
      target.build_configurations.each do |config|
        if config.build_settings['SWIFT_VERSION']
          config.build_settings['SWIFT_VERSION'] = '5.0'
        end
      end

      # 2. BRUTE-FORCE OVERRIDE FOR C++ 'fmt'
      if target.name == 'fmt'
        target.build_configurations.each do |config|
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          config.build_settings['OTHER_CFLAGS'] = '$(inherited) -DFMT_USE_CONSTEVAL=0 -DFMT_CONSTEVAL='
          config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -DFMT_USE_CONSTEVAL=0 -DFMT_CONSTEVAL='
        end
      end
    end
  end
end
